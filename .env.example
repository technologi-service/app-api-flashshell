# Neon PostgreSQL — pooled URL for Drizzle queries
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
# Neon PostgreSQL — direct URL for migrations and LISTEN/NOTIFY
DATABASE_DIRECT_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require&pgbouncer=false
# Admin seed
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme
# Better Auth
BETTER_AUTH_SECRET=change-me-in-production-min-32-chars
BETTER_AUTH_URL=http://localhost:3000
